PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/school_db
JWT_SECRET=change_me_to_a_long_random_value
# Add your current LAN IP here as well when testing from a phone, e.g. http://192.168.1.10:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000

CURRENCY=AFN
PAYMENT_MERCHANT_ID=
BANK_NAME=
BANK_ACCOUNT=
BANK_OWNER=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

ADMIN_2FA_ENABLED=true
ADMIN_2FA_LEVELS=finance_manager,finance_lead,general_president
ADMIN_2FA_CODE_TTL_SEC=300
ADMIN_2FA_CHALLENGE_TTL_SEC=900
ADMIN_2FA_RESEND_COOLDOWN_SEC=45
ADMIN_2FA_MAX_ATTEMPTS=5

FINANCE_FOUR_EYES_ENABLED=true
# Optional base URL for finance delivery provider callbacks when request host is unavailable
FINANCE_DELIVERY_BASE_URL=
PAYMENT_SIMULATION_ENABLED=false

SLA_AUTOMATION_ENABLED=true
SLA_AUTOMATION_INTERVAL_MIN=10
SLA_FINANCE_MANAGER_MIN=720
SLA_FINANCE_LEAD_MIN=1440
SLA_GENERAL_PRESIDENT_MIN=2160
